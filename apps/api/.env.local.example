# ── 로컬 개발 환경 설정 ──
# 이 파일을 .env.local로 복사하면 .env의 값을 오버라이드합니다.
# .env.local은 .gitignore 대상이므로 안전합니다.
#
# 사용법:
#   cp .env.local.example .env.local
#   npm run dev:api

# ── OAuth Redirect URI (localhost) ──
# 각 OAuth 제공자 개발자 콘솔에서 아래 URI를 "승인된 리다이렉트 URI"로 등록해야 합니다.

# 카카오: https://developers.kakao.com → 앱 → 카카오 로그인 → Redirect URI
KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/kakao/callback

# 네이버: https://developers.naver.com → 애플리케이션 → API 설정 → Callback URL
NAVER_REDIRECT_URI=http://localhost:4000/api/auth/naver/callback

# Apple: https://developer.apple.com → Certificates → Service IDs → Return URLs
# 주의: Apple은 HTTPS 필수이므로 localhost 직접 테스트 불가 → ngrok 또는 프로덕션 URI 사용
# APPLE_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/api/auth/apple/callback

# ── 서버 설정 (선택) ──
# WEB_ORIGIN=http://localhost:5173
# PORT=4000
# NODE_ENV=development
