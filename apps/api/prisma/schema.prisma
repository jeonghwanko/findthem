generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User ──

model User {
  id           String       @id @default(cuid())
  name         String
  phone        String       @unique
  email        String?
  passwordHash String?
  provider     AuthProvider @default(LOCAL)
  providerId   String?
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reports      Report[]
  sightings    Sighting[]
  chatSessions ChatSession[]

  @@map("user")
}

enum AuthProvider {
  LOCAL
  KAKAO

  @@map("auth_provider")
}

// ── Report (실종 신고) ──

model Report {
  id              String       @id @default(cuid())
  userId          String
  subjectType     SubjectType
  status          ReportStatus @default(ACTIVE)

  // 대상 정보
  name            String
  species         String?
  gender          Gender?
  age             String?
  weight          String?
  height          String?
  color           String?
  features        String
  clothingDesc    String?

  // 위치/시간
  lastSeenAt      DateTime
  lastSeenAddress String
  lastSeenLat     Float?
  lastSeenLng     Float?

  // 연락처
  contactPhone    String
  contactName     String
  reward          String?

  // AI 생성 필드
  aiDescription   String?
  aiPromoText     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  photos       ReportPhoto[]
  sightings    Sighting[]
  matches      Match[]
  promotions   Promotion[]
  chatSessions ChatSession[]

  @@index([status])
  @@index([subjectType, status])
  @@map("report")
}

enum SubjectType {
  PERSON
  DOG
  CAT

  @@map("subject_type")
}

enum ReportStatus {
  ACTIVE
  FOUND
  EXPIRED
  SUSPENDED

  @@map("report_status")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN

  @@map("gender")
}

// ── Report Photo ──

model ReportPhoto {
  id           String   @id @default(cuid())
  reportId     String
  photoUrl     String
  thumbnailUrl String?
  isPrimary    Boolean  @default(false)
  aiAnalysis   Json?
  createdAt    DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_photo")
}

// ── Sighting (목격 제보) ──

model Sighting {
  id           String         @id @default(cuid())
  reportId     String?
  userId       String?
  source       SightingSource @default(WEB)

  description  String
  sightedAt    DateTime
  address      String
  lat          Float?
  lng          Float?
  tipsterPhone String?
  tipsterName  String?

  aiAnalysis   Json?
  status       SightingStatus @default(PENDING)
  createdAt    DateTime       @default(now())

  report  Report?        @relation(fields: [reportId], references: [id])
  user    User?          @relation(fields: [userId], references: [id])
  photos  SightingPhoto[]
  matches Match[]

  @@index([reportId])
  @@index([status])
  @@map("sighting")
}

enum SightingSource {
  WEB
  KAKAO_CHATBOT
  ADMIN

  @@map("sighting_source")
}

enum SightingStatus {
  PENDING
  ANALYZED
  CONFIRMED
  REJECTED

  @@map("sighting_status")
}

model SightingPhoto {
  id           String   @id @default(cuid())
  sightingId   String
  photoUrl     String
  thumbnailUrl String?
  aiAnalysis   Json?
  createdAt    DateTime @default(now())

  sighting Sighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)

  @@map("sighting_photo")
}

// ── Match (AI 매칭 결과) ──

model Match {
  id          String      @id @default(cuid())
  reportId    String
  sightingId  String
  confidence  Float
  aiReasoning String
  status      MatchStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())

  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sighting Sighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)

  @@unique([reportId, sightingId])
  @@index([reportId, confidence])
  @@index([status])
  @@map("match")
}

enum MatchStatus {
  PENDING
  CONFIRMED
  REJECTED
  NOTIFIED

  @@map("match_status")
}

// ── Promotion (SNS 게시 기록) ──

model Promotion {
  id           String        @id @default(cuid())
  reportId     String
  platform     PromoPlatform
  postId       String?
  postUrl      String?
  content      String
  imageUrls    String[]
  status       PromoStatus   @default(PENDING)
  errorMessage String?
  postedAt     DateTime?
  createdAt    DateTime      @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, platform])
  @@map("promotion")
}

enum PromoPlatform {
  KAKAO_CHANNEL
  TWITTER

  @@map("promo_platform")
}

enum PromoStatus {
  PENDING
  POSTED
  FAILED
  DELETED

  @@map("promo_status")
}

// ── Chat Session ──

model ChatSession {
  id             String       @id @default(cuid())
  userId         String?
  reportId       String?
  platform       ChatPlatform
  platformUserId String?
  state          Json
  context        Json
  status         ChatStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user     User?         @relation(fields: [userId], references: [id])
  report   Report?       @relation(fields: [reportId], references: [id])
  messages ChatMessage[]

  @@index([platformUserId, platform])
  @@map("chat_session")
}

enum ChatPlatform {
  WEB
  KAKAO

  @@map("chat_platform")
}

enum ChatStatus {
  ACTIVE
  COMPLETED
  ABANDONED

  @@map("chat_status")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_message")
}
