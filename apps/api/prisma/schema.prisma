generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════════
// Enums
// ════════════════════════════════════════════════════════════════

enum AuthProvider {
  LOCAL
  KAKAO
  NAVER
  TELEGRAM
  APPLE

  @@map("auth_provider")
}

enum SubjectType {
  PERSON
  DOG
  CAT

  @@map("subject_type")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN

  @@map("gender")
}

enum ReportStatus {
  ACTIVE
  FOUND
  EXPIRED
  SUSPENDED

  @@map("report_status")
}

enum SightingSource {
  WEB
  KAKAO_CHATBOT
  ADMIN

  @@map("sighting_source")
}

enum SightingStatus {
  PENDING
  ANALYZED
  CONFIRMED
  REJECTED

  @@map("sighting_status")
}

enum MatchStatus {
  PENDING
  CONFIRMED
  REJECTED
  NOTIFIED

  @@map("match_status")
}

enum PromoPlatform {
  KAKAO_CHANNEL
  TWITTER
  INSTAGRAM

  @@map("promo_platform")
}

enum PromoStatus {
  PENDING
  POSTED
  FAILED
  DELETED

  @@map("promo_status")
}

enum PromoUrgency {
  HIGH
  MEDIUM
  LOW

  @@map("promo_urgency")
}

enum ChatPlatform {
  WEB
  KAKAO

  @@map("chat_platform")
}

enum ChatStatus {
  ACTIVE
  COMPLETED
  ABANDONED

  @@map("chat_status")
}

enum AdminActionSource {
  DASHBOARD
  AGENT
  API

  @@map("admin_action_source")
}

enum InquiryCategory {
  PAYMENT
  REPORT
  GENERAL
  PARTNERSHIP

  @@map("inquiry_category")
}

enum InquiryStatus {
  OPEN
  REPLIED
  CLOSED

  @@map("inquiry_status")
}

// ── P0: String → enum 전환 ──

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM

  @@map("chat_role")
}

enum RewardType {
  BADGE
  TITLE
  EFFECT

  @@map("reward_type")
}

enum XpAction {
  AD_WATCH
  SIGHTING
  COMMUNITY_POST
  COMMUNITY_COMMENT
  SHARE
  REFERRAL
  SPONSOR
  GAME

  @@map("xp_action")
}

enum SponsorCurrency {
  KRW
  USD_CENTS

  @@map("sponsor_currency")
}

enum OutreachContactType {
  JOURNALIST
  YOUTUBER
  VIDEO

  @@map("outreach_contact_type")
}

enum OutreachSource {
  GOOGLE_SEARCH
  MANUAL
  YOUTUBE_API
  VIDEO_SEARCH

  @@map("outreach_source")
}

enum OutreachRequestStatus {
  PENDING_APPROVAL
  APPROVED
  SENDING
  SENT
  FAILED
  REJECTED

  @@map("outreach_request_status")
}

enum OutreachChannel {
  EMAIL
  YOUTUBE_COMMENT

  @@map("outreach_channel")
}

enum NotificationType {
  MATCH_FOUND
  SIGHTING_RECEIVED
  REPORT_ANALYZED
  LEVEL_UP
  SYSTEM

  @@map("notification_type")
}

// ════════════════════════════════════════════════════════════════
// User & Auth
// ════════════════════════════════════════════════════════════════

model User {
  id           String       @id @default(cuid())
  name         String
  phone        String?      @unique // P0: nullable (소셜 로그인 시 null, fake phone 제거)
  email        String?
  passwordHash String?
  provider     AuthProvider @default(LOCAL)
  providerId   String?
  isVerified   Boolean      @default(false)
  locale       String       @default("ko")
  profileImage String?

  // 관리자 차단
  isBlocked   Boolean   @default(false)
  blockedAt   DateTime?
  blockReason String?

  // XP & 레벨 (P2: sponsorXp → xp, userLevel → level, sponsorXpLastAt → xpLastAt)
  xp           Int       @default(0)
  level        Int       @default(1)
  xpLastAt     DateTime? // 광고 쿨다운 체크용
  referralCode String?   @unique

  // 레퍼럴
  referredByUserId String?

  // FCM 푸시 토큰
  fcmToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports            Report[]
  sightings          Sighting[]
  chatSessions       ChatSession[]
  pushSubscriptions  PushSubscription[]
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  userRewards        UserReward[]
  gamePlays          GamePlay[]
  inquiries          Inquiry[]
  xpLogs             XpLog[]
  notifications      Notification[] // P1: new
  referredBy         User?          @relation("Referrals", fields: [referredByUserId], references: [id], onDelete: SetNull) // P1: onDelete
  referrals          User[]         @relation("Referrals")

  @@unique([provider, providerId], name: "provider_providerId")
  @@index([referredByUserId])
  @@map("user")
}

// ── User Reward (레벨업 선물) ──

model UserReward {
  id          String     @id @default(cuid())
  userId      String
  level       Int
  rewardType  RewardType // P0: String → enum
  rewardValue String?
  claimedAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, level])
  @@map("user_reward")
}

// ════════════════════════════════════════════════════════════════
// Report (실종 신고)
// ════════════════════════════════════════════════════════════════

model Report {
  id          String       @id @default(cuid())
  userId      String?
  subjectType SubjectType
  status      ReportStatus @default(ACTIVE)

  // 대상 정보
  name         String
  species      String?
  gender       Gender?
  age          String?
  weight       String?
  height       String?
  color        String?
  features     String
  clothingDesc String?

  // 위치/시간
  lastSeenAt      DateTime
  lastSeenAddress String
  lastSeenLat     Float?
  lastSeenLng     Float?
  location        Unsupported("geography(Point,4326)")? // PostGIS — trigger가 lat/lng에서 자동 생성

  // 연락처
  contactPhone String
  contactName  String
  reward       String?

  // AI 생성 필드
  aiDescription String?
  aiPromoText   String?

  // 외부 수집 데이터 식별 (크롤링 중복 방지)
  externalId     String?
  externalSource String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull) // P1: onDelete
  photos            Photo[] // P1: unified Photo (ReportPhoto + SightingPhoto → Photo)
  sightings         Sighting[]
  matches           Match[]
  promotions        Promotion[]
  chatSessions      ChatSession[]
  promotionStrategy PromotionStrategy?
  promotionLogs     PromotionLog[]
  outreachRequests  OutreachRequest[]

  @@unique([externalId, externalSource])
  @@index([status])
  @@index([subjectType, status])
  @@index([externalSource])
  // GiST index on location is created in optimize.sql (replaces B-tree lat/lng index)
  @@index([userId])
  @@index([createdAt])
  @@map("report")
}

// ════════════════════════════════════════════════════════════════
// Photo (P1: ReportPhoto + SightingPhoto → 단일 Photo 모델)
// ════════════════════════════════════════════════════════════════

model Photo {
  id           String   @id @default(cuid())
  reportId     String?
  sightingId   String?
  photoUrl     String
  thumbnailUrl String?
  isPrimary    Boolean  @default(false)
  aiAnalysis   Json?
  createdAt    DateTime @default(now())

  // exactly one of reportId/sightingId must be non-null (app-level constraint)
  report   Report?   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sighting Sighting? @relation(fields: [sightingId], references: [id], onDelete: Cascade)

  @@index([reportId, isPrimary])
  @@index([sightingId])
  @@map("photo")
}

// ════════════════════════════════════════════════════════════════
// Sighting (목격 제보)
// ════════════════════════════════════════════════════════════════

model Sighting {
  id          String         @id @default(cuid())
  reportId    String?
  userId      String?
  source      SightingSource @default(WEB)
  subjectType SubjectType?

  description  String
  sightedAt    DateTime
  address      String
  lat          Float?
  lng          Float?
  location     Unsupported("geography(Point,4326)")? // PostGIS — trigger가 lat/lng에서 자동 생성
  tipsterPhone String?
  tipsterName  String?
  editPassword String? // bcrypt — 비회원 제보 수정/삭제용

  aiAnalysis Json?
  status     SightingStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt // P2: added

  report  Report?  @relation(fields: [reportId], references: [id], onDelete: SetNull) // P1: onDelete
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)   // P1: onDelete
  photos  Photo[] // P1: unified Photo
  matches Match[]

  @@index([reportId])
  @@index([status])
  @@index([status, createdAt])
  // GiST index on location is created in optimize.sql (replaces B-tree lat/lng index)
  @@index([userId])
  @@index([createdAt])
  @@map("sighting")
}

// ════════════════════════════════════════════════════════════════
// Match (AI 매칭 결과)
// ════════════════════════════════════════════════════════════════

model Match {
  id          String      @id @default(cuid())
  reportId    String
  sightingId  String
  confidence  Float
  aiReasoning String
  status      MatchStatus @default(PENDING)
  reviewedBy  String? // admin identifier (not a User FK — admin uses API key, not user account)
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())

  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sighting Sighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)

  @@unique([reportId, sightingId])
  @@index([reportId])
  @@index([reportId, confidence])
  @@index([status])
  @@map("match")
}

// ════════════════════════════════════════════════════════════════
// Promotion (SNS 게시 기록)
// ════════════════════════════════════════════════════════════════

model Promotion {
  id           String        @id @default(cuid())
  reportId     String
  platform     PromoPlatform
  postId       String?
  postUrl      String?
  content      String
  imageUrls    String[]
  status       PromoStatus   @default(PENDING)
  errorMessage String?
  postedAt     DateTime?

  version   Int       @default(1) // repost count (이력은 PromotionLog에서 추적)
  // P2: parentId/RepostChain 제거 — @@unique([reportId, platform]) 때문에 chain 불가, PromotionLog가 이력 담당
  metrics   Json?
  metricsAt DateTime?

  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, platform])
  @@index([status])
  @@index([reportId, status, postedAt])
  @@map("promotion")
}

// ── Promotion Strategy (홍보 전략) ──

model PromotionStrategy {
  id              String          @id @default(cuid())
  reportId        String          @unique
  urgency         PromoUrgency    @default(MEDIUM)
  targetPlatforms PromoPlatform[]
  repostIntervalH Int             @default(72)
  maxReposts      Int             @default(3)
  keywords        String[]
  hashtags        String[]
  aiReasoning     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("promotion_strategy")
}

// ── Promotion Log (홍보 행동 로그, action은 String 유지 — 값 집합 확장 가능) ──

model PromotionLog {
  id        String   @id @default(dbgenerated("uuid_generate_v7()"))
  reportId  String
  action    String
  detail    Json?
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([reportId, action, createdAt])
  @@map("promotion_log")
}

// ════════════════════════════════════════════════════════════════
// Chat Session
// ════════════════════════════════════════════════════════════════

model ChatSession {
  id             String       @id @default(cuid())
  userId         String?
  reportId       String?
  platform       ChatPlatform
  platformUserId String?
  state          Json
  context        Json
  status         ChatStatus   @default(ACTIVE)
  locale         String       @default("ko")
  engineVersion  String       @default("v1")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user     User?         @relation(fields: [userId], references: [id], onDelete: SetNull)   // P1: onDelete
  report   Report?       @relation(fields: [reportId], references: [id], onDelete: SetNull) // P1: onDelete
  messages ChatMessage[]

  @@index([platformUserId, platform])
  @@index([platformUserId, platform, status])
  @@map("chat_session")
}

model ChatMessage {
  id        String   @id @default(dbgenerated("uuid_generate_v7()"))
  sessionId String
  role      ChatRole // P0: String → enum
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_message")
}

// ════════════════════════════════════════════════════════════════
// Community (커뮤니티 게시판)
// ════════════════════════════════════════════════════════════════

model ExternalAgent {
  id          String    @id @default(cuid())
  name        String
  description String?
  avatarUrl   String?
  apiKey      String    @unique
  webhookUrl  String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  posts    CommunityPost[]
  comments CommunityComment[]

  @@map("external_agent")
}

model CommunityPost {
  id               String   @id @default(cuid())
  userId           String?
  agentId          String? // internal: 'image-matching' | 'promotion' | 'chatbot-alert'
  externalAgentId  String?
  title            String
  content          String
  isPinned         Boolean  @default(false)
  viewCount        Int      @default(0)
  sourceUrl        String?
  deduplicationKey String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // exactly one of userId/agentId/externalAgentId must be non-null (app-level constraint)
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)       // P1: onDelete
  externalAgent ExternalAgent?     @relation(fields: [externalAgentId], references: [id], onDelete: SetNull) // P1: onDelete
  comments      CommunityComment[]

  @@unique([agentId, deduplicationKey])
  @@index([isPinned, createdAt])
  @@index([userId])
  @@index([agentId])
  @@index([externalAgentId])
  @@index([sourceUrl])
  @@map("community_post")
}

model CommunityComment {
  id              String   @id @default(cuid())
  postId          String
  userId          String?
  agentId         String?
  externalAgentId String?
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  post          CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)       // P1: onDelete
  externalAgent ExternalAgent? @relation(fields: [externalAgentId], references: [id], onDelete: SetNull) // P1: onDelete

  @@index([postId, createdAt])
  @@index([userId])
  @@index([externalAgentId])
  @@map("community_comment")
}

// ════════════════════════════════════════════════════════════════
// AI Settings (멀티 프로바이더 설정)
// ════════════════════════════════════════════════════════════════

model AiSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("ai_setting")
}

// ── AI Usage Log (토큰/레이턴시 추적, String 유지 — 프로바이더/모델 값 자주 변경) ──

model AiUsageLog {
  id           String   @id @default(dbgenerated("uuid_generate_v7()"))
  agentId      String
  provider     String
  model        String
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  latencyMs    Int
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([provider, createdAt])
  @@map("ai_usage_log")
}

// ── Agent Decision Log (RL 데이터, String 유지 — 이벤트/액션 타입 확장 가능) ──

model AgentDecisionLog {
  id              String   @id @default(dbgenerated("uuid_generate_v7()"))
  agentId         String
  eventType       String
  selectedAction  String
  stayedSilent    Boolean  @default(false)
  confidence      Float?
  reportId        String?
  postId          String?
  candidateScores Json
  createdAt       DateTime @default(now())

  @@index([agentId, createdAt])
  @@map("agent_decision_log")
}

// ════════════════════════════════════════════════════════════════
// Outreach (홍보왕 헤르미)
// ════════════════════════════════════════════════════════════════

model OutreachContact {
  id                String              @id @default(cuid())
  type              OutreachContactType // P0: String → enum
  name              String
  email             String?
  youtubeChannelId  String?
  youtubeChannelUrl String?
  thumbnailUrl      String?
  videoId           String?
  videoTitle        String?
  organization      String?
  topics            String[]
  subscriberCount   Int?
  viewCount         Int?
  isActive          Boolean             @default(true)
  lastContactedAt   DateTime?
  source            OutreachSource? // P0: String → enum (nullable for legacy)
  createdAt         DateTime            @default(now())

  outreachRequests OutreachRequest[]

  @@unique([email])
  @@unique([youtubeChannelId])
  @@unique([videoId])
  @@index([type, isActive])
  @@map("outreach_contact")
}

model OutreachRequest {
  id           String                @id @default(cuid())
  reportId     String
  contactId    String
  channel      OutreachChannel       // P0: String → enum
  status       OutreachRequestStatus @default(PENDING_APPROVAL) // P0: String → enum
  draftSubject String?
  draftContent String
  approvedAt   DateTime?
  sentAt       DateTime?
  externalId   String?
  errorMessage String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  report  Report          @relation(fields: [reportId], references: [id], onDelete: Cascade)
  contact OutreachContact @relation(fields: [contactId], references: [id], onDelete: Cascade) // P1: onDelete

  @@unique([reportId, contactId, channel])
  @@index([status])
  @@index([reportId, status])
  @@index([channel, sentAt])
  @@map("outreach_request")
}

// ════════════════════════════════════════════════════════════════
// Sponsor (AI 팀원 후원)
// ════════════════════════════════════════════════════════════════

model Sponsor {
  id            String          @id @default(cuid())
  agentId       String // 'image-matching' | 'promotion' | 'chatbot-alert'
  amount        Int // Toss: KRW 단위, Crypto: USD cents
  currency      SponsorCurrency @default(KRW) // P0: String → enum

  // Toss 결제
  orderId    String? @unique // P1: nullable (크립토 결제는 orderId 없음)
  paymentKey String?

  // 크립토 결제
  txHash        String? @unique
  chainId       Int?
  tokenSymbol   String?
  walletAddress String?
  quoteId       String? @unique // P1: SponsorCryptoQuote FK 추가

  // 표시
  displayName String?
  message     String?
  createdAt   DateTime @default(now())

  quote SponsorCryptoQuote? @relation(fields: [quoteId], references: [id]) // P1: 견적 → 결제 추적

  @@index([agentId, createdAt])
  @@map("sponsor")
}

// ── 크립토 결제 견적 (5분 TTL) ──

model SponsorCryptoQuote {
  id             String    @id @default(cuid())
  agentId        String
  amountUsdCents Int
  walletAddress  String
  tokenSymbol    String
  chainId        Int? // null = Solana or Aptos
  amountAtomic   String // BigInt as string
  merchantWallet String
  expiresAt      DateTime
  verifiedAt     DateTime? // 견적 사용 여부 체크 (선점 처리)
  createdAt      DateTime  @default(now())

  sponsor Sponsor? // P1: back relation

  @@index([agentId])
  @@index([expiresAt]) // P2: for cleanup jobs
  @@map("sponsor_crypto_quote")
}

// ════════════════════════════════════════════════════════════════
// XP & Game
// ════════════════════════════════════════════════════════════════

model XpLog {
  id        String   @id @default(dbgenerated("uuid_generate_v7()"))
  userId    String
  action    XpAction // P0: String → enum
  xpAmount  Int
  sourceId  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
  @@index([userId, createdAt])
  @@map("xp_log")
}

model GamePlay {
  id        String   @id @default(dbgenerated("uuid_generate_v7()"))
  userId    String?
  character String // agentId: 'image-matching' | 'promotion' | 'chatbot-alert'
  score     Int
  usedAd    Boolean  @default(false)
  gameType  String   @default("stair") // 'stair' | 'find'
  playedAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull) // P1: onDelete

  @@index([userId, playedAt])
  @@index([userId, usedAd, playedAt])
  @@index([userId, gameType, playedAt])
  @@map("game_play")
}

// ════════════════════════════════════════════════════════════════
// Notification (P1: 신규 모델 — 알림 이력)
// ════════════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(dbgenerated("uuid_generate_v7()"))
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json? // { matchId, reportId, sightingId, deepLink, etc. }
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notification")
}

// ════════════════════════════════════════════════════════════════
// Admin
// ════════════════════════════════════════════════════════════════

// ── Admin Audit Log (action/targetType는 String 유지 — 값 집합 확장 가능) ──

model AdminAuditLog {
  id             String            @id @default(dbgenerated("uuid_generate_v7()"))
  action         String
  targetType     String
  targetId       String
  detail         Json?
  source         AdminActionSource
  agentSessionId String?
  createdAt      DateTime          @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([source, createdAt])
  @@map("admin_audit_log")
}

model AdminAgentSession {
  id        String   @id @default(cuid())
  messages  Json
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_agent_session")
}

// ════════════════════════════════════════════════════════════════
// Push & Inquiry
// ════════════════════════════════════════════════════════════════

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscription")
}

model Inquiry {
  id           String          @id @default(cuid())
  userId       String?
  category     InquiryCategory
  title        String
  content      String
  status       InquiryStatus   @default(OPEN)
  replyContent String?
  repliedAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull) // P1: onDelete

  @@index([userId])
  @@index([status])
  @@map("inquiry")
}
