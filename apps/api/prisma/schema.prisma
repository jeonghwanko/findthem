generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User ──

model User {
  id           String       @id @default(cuid())
  name         String
  phone        String       @unique
  email        String?
  passwordHash String?
  provider     AuthProvider @default(LOCAL)
  providerId   String?
  isVerified   Boolean      @default(false)
  locale       String       @default("ko")
  profileImage String?

  // 관리자 차단
  isBlocked   Boolean   @default(false)
  blockedAt   DateTime?
  blockReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports            Report[]
  sightings          Sighting[]
  chatSessions       ChatSession[]
  pushSubscriptions  PushSubscription[]
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]

  @@unique([provider, providerId], name: "provider_providerId")
  @@map("user")
}

enum AuthProvider {
  LOCAL
  KAKAO
  NAVER
  TELEGRAM

  @@map("auth_provider")
}

// ── Report (실종 신고) ──

model Report {
  id          String       @id @default(cuid())
  userId      String?
  subjectType SubjectType
  status      ReportStatus @default(ACTIVE)

  // 대상 정보
  name         String
  species      String?
  gender       Gender?
  age          String?
  weight       String?
  height       String?
  color        String?
  features     String
  clothingDesc String?

  // 위치/시간
  lastSeenAt      DateTime
  lastSeenAddress String
  lastSeenLat     Float?
  lastSeenLng     Float?

  // 연락처
  contactPhone String
  contactName  String
  reward       String?

  // AI 생성 필드
  aiDescription String?
  aiPromoText   String?

  // 외부 수집 데이터 식별 (크롤링 중복 방지)
  externalId     String?
  externalSource String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User?              @relation(fields: [userId], references: [id])
  photos            ReportPhoto[]
  sightings         Sighting[]
  matches           Match[]
  promotions        Promotion[]
  chatSessions      ChatSession[]
  promotionStrategy PromotionStrategy?
  promotionLogs     PromotionLog[]
  outreachRequests  OutreachRequest[]

  @@unique([externalId, externalSource])
  @@index([status])
  @@index([subjectType, status])
  @@index([externalSource])
  @@index([lastSeenLat, lastSeenLng])
  @@map("report")
}

enum SubjectType {
  PERSON
  DOG
  CAT

  @@map("subject_type")
}

enum ReportStatus {
  ACTIVE
  FOUND
  EXPIRED
  SUSPENDED

  @@map("report_status")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN

  @@map("gender")
}

// ── Report Photo ──

model ReportPhoto {
  id           String   @id @default(cuid())
  reportId     String
  photoUrl     String
  thumbnailUrl String?
  isPrimary    Boolean  @default(false)
  aiAnalysis   Json?
  createdAt    DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_photo")
}

// ── Sighting (목격 제보) ──

model Sighting {
  id          String         @id @default(cuid())
  reportId    String?
  userId      String?
  source      SightingSource @default(WEB)
  subjectType SubjectType?

  description  String
  sightedAt    DateTime
  address      String
  lat          Float?
  lng          Float?
  tipsterPhone String?
  tipsterName  String?

  aiAnalysis Json?
  status     SightingStatus @default(PENDING)
  createdAt  DateTime       @default(now())

  report  Report?         @relation(fields: [reportId], references: [id])
  user    User?           @relation(fields: [userId], references: [id])
  photos  SightingPhoto[]
  matches Match[]

  @@index([reportId])
  @@index([status])
  @@index([lat, lng])
  @@map("sighting")
}

enum SightingSource {
  WEB
  KAKAO_CHATBOT
  ADMIN

  @@map("sighting_source")
}

enum SightingStatus {
  PENDING
  ANALYZED
  CONFIRMED
  REJECTED

  @@map("sighting_status")
}

model SightingPhoto {
  id           String   @id @default(cuid())
  sightingId   String
  photoUrl     String
  thumbnailUrl String?
  aiAnalysis   Json?
  createdAt    DateTime @default(now())

  sighting Sighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)

  @@index([sightingId])
  @@map("sighting_photo")
}

// ── Match (AI 매칭 결과) ──

model Match {
  id          String      @id @default(cuid())
  reportId    String
  sightingId  String
  confidence  Float
  aiReasoning String
  status      MatchStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())

  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sighting Sighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)

  @@unique([reportId, sightingId])
  @@index([reportId, confidence])
  @@index([status])
  @@map("match")
}

enum MatchStatus {
  PENDING
  CONFIRMED
  REJECTED
  NOTIFIED

  @@map("match_status")
}

// ── Promotion (SNS 게시 기록) ──

model Promotion {
  id           String        @id @default(cuid())
  reportId     String
  platform     PromoPlatform
  postId       String?
  postUrl      String?
  content      String
  imageUrls    String[]
  status       PromoStatus   @default(PENDING)
  errorMessage String?
  postedAt     DateTime?

  // 재게시 지원
  version   Int       @default(1)
  parentId  String?
  metrics   Json?
  metricsAt DateTime?

  createdAt DateTime @default(now())

  report  Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  parent  Promotion?  @relation("RepostChain", fields: [parentId], references: [id])
  reposts Promotion[] @relation("RepostChain")

  @@unique([reportId, platform])
  @@index([status])
  @@index([reportId, status, postedAt])
  @@map("promotion")
}

enum PromoPlatform {
  KAKAO_CHANNEL
  TWITTER

  @@map("promo_platform")
}

enum PromoStatus {
  PENDING
  POSTED
  FAILED
  DELETED

  @@map("promo_status")
}

// ── Chat Session ──

model ChatSession {
  id             String       @id @default(cuid())
  userId         String?
  reportId       String?
  platform       ChatPlatform
  platformUserId String?
  state          Json
  context        Json
  status         ChatStatus   @default(ACTIVE)
  locale         String       @default("ko")
  engineVersion  String       @default("v1")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user     User?         @relation(fields: [userId], references: [id])
  report   Report?       @relation(fields: [reportId], references: [id])
  messages ChatMessage[]

  @@index([platformUserId, platform])
  @@index([platformUserId, platform, status])
  @@map("chat_session")
}

enum ChatPlatform {
  WEB
  KAKAO

  @@map("chat_platform")
}

enum ChatStatus {
  ACTIVE
  COMPLETED
  ABANDONED

  @@map("chat_status")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_message")
}

// ── Promotion Strategy (홍보 전략) ──

model PromotionStrategy {
  id              String          @id @default(cuid())
  reportId        String          @unique
  urgency         PromoUrgency    @default(MEDIUM)
  targetPlatforms PromoPlatform[]
  repostIntervalH Int             @default(72)
  maxReposts      Int             @default(3)
  keywords        String[]
  hashtags        String[]
  aiReasoning     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("promotion_strategy")
}

enum PromoUrgency {
  HIGH
  MEDIUM
  LOW

  @@map("promo_urgency")
}

// ── Promotion Log (홍보 행동 로그) ──

model PromotionLog {
  id        String   @id @default(cuid())
  reportId  String
  action    String
  detail    Json?
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@map("promotion_log")
}

// ── Push Subscription (웹 푸시 구독) ──

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscription")
}

// ── Admin Audit Log (관리자 감사 로그) ──

model AdminAuditLog {
  id             String            @id @default(cuid())
  action         String
  targetType     String
  targetId       String
  detail         Json?
  source         AdminActionSource
  agentSessionId String?
  createdAt      DateTime          @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([source, createdAt])
  @@map("admin_audit_log")
}

enum AdminActionSource {
  DASHBOARD
  AGENT
  API

  @@map("admin_action_source")
}

// ── Admin Agent Session (운영 에이전트 세션) ──

model AdminAgentSession {
  id        String   @id @default(cuid())
  messages  Json
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_agent_session")
}

// ── Sponsor (AI 팀원 후원) ──

model Sponsor {
  id            String   @id @default(cuid())
  agentId       String // 'image-matching' | 'promotion' | 'chatbot-alert'
  // Toss: KRW 단위, Crypto: USD cents
  amount        Int
  currency      String   @default("KRW") // "KRW" | "USD_CENTS"
  // Toss 결제
  orderId       String   @unique
  paymentKey    String?
  // 크립토 결제
  txHash        String?  @unique
  chainId       Int?
  tokenSymbol   String?
  walletAddress String?
  displayName   String?
  message       String?
  createdAt     DateTime @default(now())

  @@index([agentId])
  @@map("sponsor")
}

// ── Outreach (홍보왕 헤르미) ──

model OutreachContact {
  id                String    @id @default(cuid())
  type              String // 'JOURNALIST' | 'YOUTUBER' | 'VIDEO'
  name              String
  email             String?
  youtubeChannelId  String?
  youtubeChannelUrl String?
  videoId           String?   // VIDEO 타입: 유튜브 영상 ID
  videoTitle        String?   // VIDEO 타입: 영상 제목
  organization      String?
  topics            String[]
  subscriberCount   Int?
  viewCount         Int?      // VIDEO 타입: 영상 조회수
  isActive          Boolean   @default(true)
  lastContactedAt   DateTime?
  source            String? // 'GOOGLE_SEARCH' | 'MANUAL' | 'YOUTUBE_API' | 'VIDEO_SEARCH'
  createdAt         DateTime  @default(now())

  outreachRequests OutreachRequest[]

  @@unique([email])
  @@unique([youtubeChannelId])
  @@unique([videoId])
  @@index([type, isActive])
  @@map("outreach_contact")
}

model OutreachRequest {
  id           String    @id @default(cuid())
  reportId     String
  contactId    String
  channel      String // 'EMAIL' | 'YOUTUBE_COMMENT'
  status       String    @default("PENDING_APPROVAL")
  draftSubject String?
  draftContent String
  approvedAt   DateTime?
  sentAt       DateTime?
  externalId   String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  report  Report          @relation(fields: [reportId], references: [id], onDelete: Cascade)
  contact OutreachContact @relation(fields: [contactId], references: [id])

  @@unique([reportId, contactId, channel])
  @@index([status])
  @@map("outreach_request")
}

// ── Community (커뮤니티 게시판) ──

model ExternalAgent {
  id          String   @id @default(cuid())
  name        String
  description String?
  avatarUrl   String?
  apiKey      String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?

  posts    CommunityPost[]
  comments CommunityComment[]

  @@map("external_agent")
}

model CommunityPost {
  id               String   @id @default(cuid())
  userId           String?
  agentId          String?  // 'image-matching' | 'promotion' | 'chatbot-alert'
  externalAgentId  String?
  title            String
  content          String
  isPinned         Boolean  @default(false)
  viewCount        Int      @default(0)
  deduplicationKey String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User?              @relation(fields: [userId], references: [id])
  externalAgent ExternalAgent?     @relation(fields: [externalAgentId], references: [id])
  comments      CommunityComment[]

  @@unique([agentId, deduplicationKey])
  @@index([isPinned, createdAt])
  @@index([userId])
  @@index([agentId])
  @@index([externalAgentId])
  @@map("community_post")
}

model CommunityComment {
  id              String   @id @default(cuid())
  postId          String
  userId          String?
  agentId         String?
  externalAgentId String?
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  post          CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id])
  externalAgent ExternalAgent? @relation(fields: [externalAgentId], references: [id])

  @@index([postId, createdAt])
  @@index([userId])
  @@index([externalAgentId])
  @@map("community_comment")
}

// ── AI Settings (멀티 프로바이더 설정) ──

model AiSetting {
  id        String   @id @default(cuid())
  key       String   @unique // 'default_provider', 'default_model', 'agent:image-matching:provider', etc.
  value     String
  updatedAt DateTime @updatedAt

  @@map("ai_setting")
}

// ── AI Usage Log (토큰/레이턴시 추적) ──

model AiUsageLog {
  id           String   @id @default(cuid())
  agentId      String // 'image-matching', 'promotion', 'chatbot', 'outreach', 'crawl', 'admin', 'devlog'
  provider     String // 'anthropic', 'gemini', 'openai'
  model        String // 'claude-sonnet-4-20250514', 'gemini-2.0-flash', 'gpt-4o-mini'
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  latencyMs    Int
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([provider, createdAt])
  @@map("ai_usage_log")
}

// 크립토 결제 견적 (5분 TTL)
model SponsorCryptoQuote {
  id             String    @id @default(cuid())
  agentId        String
  amountUsdCents Int
  walletAddress  String
  tokenSymbol    String
  chainId        Int? // null = Solana or Aptos
  amountAtomic   String // BigInt as string
  merchantWallet String
  expiresAt      DateTime
  verifiedAt     DateTime? // 견적 사용 여부 체크 (선점 처리)
  createdAt      DateTime  @default(now())

  @@index([agentId])
  @@map("sponsor_crypto_quote")
}
