# ============================================
# FindThem API — 환경변수 템플릿
# cp .env.example .env 후 값을 채워주세요
# ============================================

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5433/union

# ── Redis (BullMQ) ──
REDIS_URL=redis://localhost:6380

# ── Server ──
PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads
SITE_URL=https://union.pryzm.gg

# ── Auth (JWT) ──
JWT_SECRET=change-me-in-production          # 프로덕션 필수
JWT_EXPIRES_IN=7d

# ── Admin ──
ADMIN_API_KEY=dev-admin-key                 # 프로덕션 필수

# ── AI Agent 개별 인증키 (커뮤니티 API 인증) ──
# 각 에이전트가 커뮤니티에 글/댓글 작성 시 X-Agent-Key + X-Agent-Id 헤더로 인증
# 에이전트마다 고유 키 → 클로드 키로 헤르미 행세 불가 (교차 사용 차단)
# 프로덕션에서는 반드시 강한 랜덤값으로 변경
AGENT_KEY_IMAGE_MATCHING=dev-agent-key-im   # 탐정 클로드 — 사진 분석 & 매칭
AGENT_KEY_PROMOTION=dev-agent-key-promo     # 홍보왕 헤르미 — SNS 홍보
AGENT_KEY_CHATBOT_ALERT=dev-agent-key-chat  # 안내봇 알리 — 챗봇 & 알림

# ── Anthropic Claude ──
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Gemini (선택) ──
# GEMINI_API_KEY=

# ── OpenAI (선택) ──
# OPENAI_API_KEY=

# ── KakaoTalk ──
KAKAO_REST_API_KEY=
KAKAO_ADMIN_KEY=
KAKAO_CHANNEL_ID=
KAKAO_CHANNEL_PUBLIC_KEY=
KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/kakao/callback

# ── Twitter/X ──
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── Geocoding (Kakao Map) ──
KAKAO_MAP_REST_KEY=

# ── 공공데이터포털 API ──
PUBLIC_DATA_API_KEY=
SAFE182_ESNTL_ID=
SAFE182_API_KEY=

# ── Naver ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:4000/api/auth/naver/callback

# ── Telegram ──
# TELEGRAM_BOT_TOKEN=

# ── Ghost CMS (데브로그) ──
GHOST_ADMIN_API_KEY=
GHOST_API_URL=https://union.pryzm.gg/devlog
DEVLOG_REPO_PATH=.

# ── Web Push (VAPID) ──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@union.pryzm.gg

# ── Toss Payments ──
TOSS_SECRET_KEY=

# ── Crypto Wallets (후원 수금) ──
# MERCHANT_WALLET_EVM=0x...
# MERCHANT_WALLET_APTOS=0x...
# MERCHANT_WALLET_SOLANA=...

# ── Aptos/Solana RPC ──
# APTOS_RPC_URL=https://api.mainnet.aptoslabs.com/v1
# APTOS_RPC_API_KEY=
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Google (Outreach) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
YOUTUBE_API_KEY=
OUTREACH_EMAIL_FROM=

# ── ERC-8004 Agent Wallets (에이전트별 개별 지갑) ──
# Base 체인 Identity Registry에 에이전트 NFT를 등록하는 스크립트용
# 각 에이전트가 독립된 지갑으로 등록 → on-chain identity 분리
# 등록 후 각 에이전트는 고유한 agentId(ERC-721 tokenId)를 받음
#
# 실행:
#   테스트넷: node scripts/erc8004/register-agents.mjs --testnet
#   메인넷:  node scripts/erc8004/register-agents.mjs
#   특정만:  node scripts/erc8004/register-agents.mjs --only image-matching
#
# 컨트랙트 주소:
#   Base Mainnet: 0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
#   Base Sepolia: 0x8004A818BFB912233c491871b3d84c89A494BD9e
#
# 각 지갑에 Base ETH 잔고 필요 (약 0.0003 ETH/에이전트)
AGENT_WALLET_PK_IMAGE_MATCHING=0x...        # 탐정 클로드 지갑
AGENT_WALLET_PK_PROMOTION=0x...             # 홍보왕 헤르미 지갑
AGENT_WALLET_PK_CHATBOT_ALERT=0x...         # 안내봇 알리 지갑
# BASE_RPC_URL=https://mainnet.base.org     # 커스텀 RPC (선택)
