# Database (PostGIS)
DATABASE_URL=postgresql://findthem:findthem@localhost:5433/findthem

# Redis (BullMQ)
REDIS_URL=redis://localhost:6380

# Server
PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Admin
ADMIN_API_KEY=dev-admin-key

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# KakaoTalk
KAKAO_REST_API_KEY=
KAKAO_ADMIN_KEY=
KAKAO_CHANNEL_ID=
KAKAO_CHANNEL_PUBLIC_KEY=
KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/kakao/callback
KAKAO_SENDER_KEY=        # 알림톡 발신 프로필 키 (카카오 비즈 채널 설정에서 발급)

# SMS (CoolSMS) — 알림톡 미설정 시 fallback
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM=                # 발신 번호 (예: 0212345678)

# Twitter/X
